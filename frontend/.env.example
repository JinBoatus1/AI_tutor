# ---------- API root URL for the browser (embedded in the production bundle) ----------
# Production builds load frontend/.env.production by default (pointing at Render in this repo).
# If frontend and API share one origin with /api reverse-proxied, remove or empty VITE_API_URL for relative /api.
# On Vercel, vercel.json can proxy /api to Render; VITE_API_URL may stay empty. If you change the API host, update vercel.json too.
# VITE_API_URL=https://your-api.example.com

# ---------- Local npm run dev / vite preview only: where Vite proxies /api ----------
# Default matches .env.production (public Render). For local uvicorn only, uncomment and set your port.
# DEV_API_PROXY_TARGET=http://127.0.0.1:8000
